<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_row"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView android:id="@+id/tv_serial" android:layout_width="100dp" android:layout_height="wrap_content" android:textSize="12sp" />
    <TextView android:id="@+id/tv_name" android:layout_width="150dp" android:layout_height="wrap_content" android:textSize="12sp" />
    <TextView android:id="@+id/tv_author" android:layout_width="120dp" android:layout_height="wrap_content" android:textSize="12sp" />
    <TextView android:id="@+id/tv_category" android:layout_width="100dp" android:layout_height="wrap_content" android:textSize="12sp" />
    <TextView android:id="@+id/tv_status" android:layout_width="80dp" android:layout_height="wrap_content" android:textSize="12sp" />
    <TextView android:id="@+id/tv_cost" android:layout_width="80dp" android:layout_height="wrap_content" android:textSize="12sp" />
    <TextView android:id="@+id/tv_date" android:layout_width="100dp" android:layout_height="wrap_content" android:textSize="12sp" />

</LinearLayout>
